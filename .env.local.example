# Copy this to .env.local and fill in your values

# Required for Loan Genie AI scorer (Groq Cloud — get key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Mapbox token for City IoT (currently uses canvas simulation)
# NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# GCS bucket name containing your resume PDF (bucket must be publicly readable)
GCS_RESUME_BUCKET=
